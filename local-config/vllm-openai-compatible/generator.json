{
  "default_provider": "openai",
  "providers": {
    "openai": {
      "name": "OpenAI-Compatible (vLLM)",
      "supportsCustomModel": true,
      "initialize_kwargs": {
        "api_key": "EMPTY",
        "env_base_url_name": "VLLM_OPENAI_BASE_URL"
      },
      "default_model": "qwen3.5:9b",
      "models": {
        "qwen3.5:9b": {
          "name": "Qwen 3.5 9B Instruct",
          "temperature": 0.3,
          "top_p": 0.8
        },
        "qwen3.5-32b-instruct": {
          "name": "Qwen 3.5 32B Instruct",
          "temperature": 0.3,
          "top_p": 0.8
        },
        "gemma-3-27b-it": {
          "name": "Gemma 3 27B IT",
          "temperature": 0.3,
          "top_p": 0.8
        }
      }
    }
  }
}
