{
  "embedder": {
    "client_class": "OpenAIClient",
    "initialize_kwargs": {
      "env_api_key_name": "OLLAMA_OPENAI_API_KEY",
      "env_base_url_name": "OLLAMA_OPENAI_BASE_URL"
    },
    "batch_size": 100,
    "model_kwargs": {
      "model": "embeddinggemma",
      "encoding_format": "float"
    }
  },
  "retriever": {
    "top_k": 20
  },
  "text_splitter": {
    "split_by": "word",
    "chunk_size": 350,
    "chunk_overlap": 100
  }
}
