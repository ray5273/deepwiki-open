{
  "default_provider": "openai",
  "providers": {
    "openai": {
      "name": "OpenAI-Compatible (Local Ollama)",
      "supportsCustomModel": true,
      "initialize_kwargs": {
        "env_api_key_name": "OLLAMA_OPENAI_API_KEY",
        "env_base_url_name": "OLLAMA_OPENAI_BASE_URL"
      },
      "default_model": "qwen3.5:9b",
      "models": {
        "qwen3.5:9b": {
          "name": "Qwen 3.5 9B",
          "temperature": 0.3,
          "top_p": 0.8
        },
        "qwen3:14b": {
          "name": "Qwen 3 14B",
          "temperature": 0.3,
          "top_p": 0.8
        },
        "qwen3:4b": {
          "name": "Qwen 3 4B",
          "temperature": 0.3,
          "top_p": 0.8
        },
        "qwen3.5:27b": {
          "name": "Qwen 3.5 27B",
          "temperature": 0.3,
          "top_p": 0.8
        }
      }
    }
  }
}
